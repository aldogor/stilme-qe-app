<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_scale_group"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    style="@style/Widget.StudioSTILMEQE.Card.Outlined">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Scale title -->
        <TextView
            android:id="@+id/text_scale_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BSMAS"
            android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
            android:textColor="?attr/colorPrimary" />

        <!-- Scale instructions -->
        <TextView
            android:id="@+id/text_scale_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:text="Durante l'ultimo anno con quale frequenza..."
            android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
            android:textStyle="italic" />

        <!-- Legend row with numbers - aligned with radio buttons -->
        <LinearLayout
            android:id="@+id/legend_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_legend"
            android:gravity="top"
            android:orientation="horizontal"
            android:paddingVertical="12dp"
            android:paddingHorizontal="12dp">

            <!-- Label on the left -->
            <TextView
                android:id="@+id/text_legend_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Legenda:"
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary"
                android:textStyle="italic" />

            <!-- Legend items - aligned with radio buttons (180dp) -->
            <LinearLayout
                android:id="@+id/legend_items"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal" />

        </LinearLayout>

        <!-- Questions container -->
        <LinearLayout
            android:id="@+id/questions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:showDividers="middle"
            android:divider="@drawable/divider_horizontal" />

        <!-- Completion indicator -->
        <LinearLayout
            android:id="@+id/completion_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@drawable/bg_completion_indicator"
            android:paddingVertical="8dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/text_completion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/6 risposte"
                android:textAppearance="@style/TextAppearance.StudioSTILMEQE.LabelLarge"
                android:textColor="?android:textColorSecondary" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
