<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/consent_title"
            android:textAppearance="@style/TextAppearance.StudioSTILMEQE.HeadlineMedium"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/consent_subtitle"
            android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
            android:textColor="?android:textColorSecondary"
            android:gravity="center" />

        <!-- Consent Text Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.StudioSTILMEQE.Card.Outlined">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:scrollbars="vertical"
                android:fadeScrollbars="false">

                <TextView
                    android:id="@+id/text_consent_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="@string/consent_full_text"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                    android:lineSpacingMultiplier="1.5" />

            </androidx.core.widget.NestedScrollView>
        </com.google.android.material.card.MaterialCardView>

        <!-- Consent Questions (Yes/No) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.StudioSTILMEQE.Card.Outlined">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Question 1: Informed Consent -->
                <TextView
                    android:id="@+id/text_question_informed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/consent_question_informed"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                    android:lineSpacingMultiplier="1.3" />

                <RadioGroup
                    android:id="@+id/radio_group_informed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_informed_yes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/consent_answer_yes"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium" />

                    <RadioButton
                        android:id="@+id/radio_informed_no"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/consent_answer_no"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium" />

                </RadioGroup>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="?android:attr/listDivider" />

                <!-- Question 2: Privacy Consent -->
                <TextView
                    android:id="@+id/text_question_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/consent_question_privacy"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                    android:lineSpacingMultiplier="1.3" />

                <RadioGroup
                    android:id="@+id/radio_group_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_privacy_yes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/consent_answer_yes"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium" />

                    <RadioButton
                        android:id="@+id/radio_privacy_no"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/consent_answer_no"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium" />

                </RadioGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Buttons -->
        <Button
            android:id="@+id/button_accept"
            style="@style/Widget.StudioSTILMEQE.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/consent_accept"
            android:enabled="false" />

    </LinearLayout>
</ScrollView>
