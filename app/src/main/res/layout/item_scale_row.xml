<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingVertical="10dp">

    <!-- Question number -->
    <TextView
        android:id="@+id/text_row_number"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:background="@drawable/bg_row_number"
        android:gravity="center"
        android:text="1"
        android:textColor="?android:textColorSecondary"
        android:textSize="11sp" />

    <!-- Question text - flexible width, no maxLines -->
    <TextView
        android:id="@+id/text_row_question"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="12dp"
        android:text="Question text here"
        android:textColor="?android:textColorPrimary"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.2" />

    <!-- Radio buttons container - fixed width for consistent alignment -->
    <LinearLayout
        android:id="@+id/radio_container"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal" />

</LinearLayout>
