<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp"
            android:gravity="center_horizontal">

            <!-- App Icon -->
            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="@string/app_name"
                android:layout_marginBottom="16dp" />

            <!-- App Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_title"
                android:textAppearance="@style/TextAppearance.StudioSTILMEQE.HeadlineMedium"
                android:textAlignment="center" />

            <!-- Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                style="@style/Widget.StudioSTILMEQE.Card.Outlined">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/main_status_title"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/text_study_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyLarge"
                        tools:text="Prossimo questionario tra 15 giorni" />

                    <!-- Study Progress -->
                    <LinearLayout
                        android:id="@+id/progress_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical">

                        <!-- Progress text (e.g., "Mese 2 di 4") -->
                        <TextView
                            android:id="@+id/text_progress_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.StudioSTILMEQE.LabelLarge"
                            android:textColor="?android:textColorSecondary"
                            tools:text="Mese 2 di 4" />

                        <!-- Progress bar -->
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progress_bar"
                            style="@style/Widget.StudioSTILMEQE.ProgressIndicator"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:max="5"
                            android:progress="1" />

                    </LinearLayout>

                    <!-- Data collection info note -->
                    <TextView
                        android:id="@+id/text_info_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/main_info_text"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                        android:textColor="?android:textColorHint"
                        android:textSize="11sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Questionnaire notification card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_questionnaire"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                style="@style/Widget.StudioSTILMEQE.Card.Outlined"
                app:strokeColor="@color/primary"
                app:strokeWidth="2dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/questionnaire_due"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/text_questionnaire_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                        android:text="@string/questionnaire_due_description" />

                    <Button
                        android:id="@+id/button_open_questionnaire"
                        style="@style/Widget.StudioSTILMEQE.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/open_questionnaire" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Group Instructions Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_group_instructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                style="@style/Widget.StudioSTILMEQE.Card.Outlined">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/main_group_card_title"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/main_group_card_description"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                        android:textColor="?android:textColorSecondary" />

                    <Button
                        android:id="@+id/button_view_instructions"
                        style="@style/Widget.StudioSTILMEQE.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/main_group_card_button" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Contact Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_contact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                style="@style/Widget.StudioSTILMEQE.Card.Outlined">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contact_title"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/contact_description"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                        android:textColor="?android:textColorSecondary" />

                    <Button
                        android:id="@+id/button_contact"
                        style="@style/Widget.StudioSTILMEQE.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/contact_email" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/contact_anonymous_note"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                        android:textColor="?android:textColorHint"
                        android:textSize="11sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Invite Friends Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_invite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                style="@style/Widget.StudioSTILMEQE.Card.Outlined">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/main_invite_title"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/main_invite_description"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                        android:textColor="?android:textColorSecondary" />

                    <Button
                        android:id="@+id/button_invite"
                        style="@style/Widget.StudioSTILMEQE.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/main_invite_button" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- More info link -->
            <Button
                android:id="@+id/button_more_info"
                style="@style/Widget.StudioSTILMEQE.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/welcome_more_info"
                app:icon="@android:drawable/ic_menu_info_details"
                app:iconGravity="start" />

            <!-- Spacer to push debug section to bottom -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="32dp" />

            <!-- Debug buttons (hidden in production, available for development) -->
            <LinearLayout
                android:id="@+id/debug_buttons_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/button_export_csv"
                    style="@style/Widget.StudioSTILMEQE.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="@string/export_csv_debug"
                    android:textSize="11sp" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="match_parent" />

                <Button
                    android:id="@+id/button_debug_skip"
                    style="@style/Widget.StudioSTILMEQE.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="@string/debug_skip_month"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Withdrawal Section -->
            <TextView
                android:id="@+id/button_withdraw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/withdraw_button"
                android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                android:textColor="?android:textColorHint"
                android:textSize="12sp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

        </LinearLayout>
    </ScrollView>

    <!-- Withdrawal confirmation overlay -->
    <FrameLayout
        android:id="@+id/withdraw_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_background"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:contentDescription="@string/a11y_withdraw_dialog"
        android:importantForAccessibility="yes">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="24dp"
            style="@style/Widget.StudioSTILMEQE.Card.Elevated"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/text_withdraw_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/withdraw_dialog_title"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleLarge"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/text_withdraw_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/withdraw_dialog_message"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                    android:textColor="?android:textColorSecondary"
                    android:lineSpacingMultiplier="1.3" />

                <!-- Input field for final confirmation (initially hidden) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_withdraw_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_withdraw_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/withdraw_confirm_hint"
                        android:inputType="textCapCharacters"
                        android:maxLines="1" />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_withdraw_cancel"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cancel" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_withdraw_confirm"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/withdraw_confirm_step1"
                        android:textColor="@color/error" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- Loading overlay for withdrawal -->
    <FrameLayout
        android:id="@+id/withdraw_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_background"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:contentDescription="@string/a11y_loading"
        android:importantForAccessibility="yes">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            style="@style/Widget.StudioSTILMEQE.Card.Elevated"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="?attr/colorPrimary"
                    app:trackColor="@color/progress_track" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/withdraw_loading"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyLarge" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
