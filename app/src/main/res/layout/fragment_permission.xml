<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permission_title"
            android:textAppearance="@style/TextAppearance.StudioSTILMEQE.HeadlineMedium"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/permission_explanation"
            android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyLarge"
            android:textColor="?android:textColorSecondary"
            android:gravity="center" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- Usage Stats Permission Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_usage_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.StudioSTILMEQE.Card.Outlined">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/usage_status_indicator"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_status_dot_error"
                        android:contentDescription="@string/a11y_usage_permission_status"
                        android:importantForAccessibility="yes" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="@string/permission_usage_title"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/usage_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_status_denied"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                        android:textColor="@color/error" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="24dp"
                    android:text="@string/permission_usage_description"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                    android:textColor="?android:textColorSecondary" />

                <TextView
                    android:id="@+id/text_usage_help"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="24dp"
                    android:text="@string/permission_usage_help"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/button_grant_usage"
                    style="@style/Widget.StudioSTILMEQE.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/permission_grant_usage_button"
                    android:textSize="13sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Notification Permission Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_notification_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/Widget.StudioSTILMEQE.Card.Outlined">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/notification_status_indicator"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_status_dot_error"
                        android:contentDescription="@string/a11y_notification_permission_status"
                        android:importantForAccessibility="yes" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="@string/permission_notification_title"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/notification_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_status_denied"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                        android:textColor="@color/error" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="24dp"
                    android:text="@string/permission_notification_description"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                    android:textColor="?android:textColorSecondary" />

                <Button
                    android:id="@+id/button_grant_notification"
                    style="@style/Widget.StudioSTILMEQE.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/permission_grant_notification_button"
                    android:textSize="13sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Battery Optimization Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_battery_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/Widget.StudioSTILMEQE.Card.Outlined">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/battery_status_indicator"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_status_dot_error"
                        android:contentDescription="@string/a11y_battery_permission_status"
                        android:importantForAccessibility="yes" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="@string/permission_battery_title"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/battery_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_status_denied"
                        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                        android:textColor="@color/error" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="24dp"
                    android:text="@string/permission_battery_description"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodySmall"
                    android:textColor="?android:textColorSecondary" />

                <Button
                    android:id="@+id/button_grant_battery"
                    style="@style/Widget.StudioSTILMEQE.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/permission_grant_battery_button"
                    android:textSize="13sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/button_continue"
            style="@style/Widget.StudioSTILMEQE.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/continue_button"
            android:enabled="false" />

    </LinearLayout>
</ScrollView>
