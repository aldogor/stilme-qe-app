<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <!-- Title and subtitle -->
        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.StudioSTILMEQE.HeadlineMedium" />

        <TextView
            android:id="@+id/text_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
            android:textColor="?android:textColorSecondary" />

        <!-- Main instructions card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.StudioSTILMEQE.Card.Outlined">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/text_instructions_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
                    android:textColor="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/text_instructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Important notice card (STL group only) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_important"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            style="@style/Widget.StudioSTILMEQE.Card"
            app:cardBackgroundColor="@color/warning_container"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/text_important_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
                    android:textColor="@color/warning" />

                <TextView
                    android:id="@+id/text_important_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                    android:textColor="@color/on_warning_container" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- STL setup instructions card (STL group only) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_stl_setup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            style="@style/Widget.StudioSTILMEQE.Card.Outlined"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/text_setup_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
                    android:textColor="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/text_setup_instructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PDF guide download button (STL group only) -->
        <Button
            android:id="@+id/button_download_pdf"
            style="@style/Widget.StudioSTILMEQE.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/group_stl_pdf_button"
            android:visibility="gone"
            app:icon="@android:drawable/ic_menu_save"
            app:iconGravity="start" />

        <!-- Apps list card (STL group only) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_apps_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            style="@style/Widget.StudioSTILMEQE.Card.Outlined"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/text_apps_list_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.TitleMedium"
                    android:textColor="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/text_apps_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- More info link -->
        <Button
            android:id="@+id/button_more_info"
            style="@style/Widget.StudioSTILMEQE.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/group_instructions_more_info"
            app:icon="@android:drawable/ic_menu_info_details"
            app:iconGravity="start" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <Button
            android:id="@+id/button_continue"
            style="@style/Widget.StudioSTILMEQE.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/group_instructions_done" />

    </LinearLayout>
</ScrollView>
