<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Current status info -->
    <TextView
        android:id="@+id/text_debug_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.BodyMedium"
        android:lineSpacingMultiplier="1.4"
        android:padding="12dp"
        android:background="@drawable/bg_debug_info" />

    <!-- Quick jump buttons -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/debug_quick_jump"
        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.LabelLarge"
        android:textColor="?android:textColorSecondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_jump_1"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="+1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_jump_7"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="+7" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_jump_14"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="+14" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_jump_30"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="+30" />

    </LinearLayout>

    <!-- Custom input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/debug_custom_days"
        android:textAppearance="@style/TextAppearance.StudioSTILMEQE.LabelLarge"
        android:textColor="?android:textColorSecondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_custom_days"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:suffixText="@string/debug_days_suffix">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_custom_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:hint="@string/debug_days_hint"
                android:maxLength="3" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_jump_custom"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/debug_jump_button" />

    </LinearLayout>

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <!-- Reset button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_reset"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/debug_reset_button"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconGravity="start" />

        <!-- Test notification button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_test_notification"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/debug_test_notification"
            app:icon="@android:drawable/ic_popup_reminder"
            app:iconGravity="start" />

    </LinearLayout>

</LinearLayout>
