<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Permission to query app usage statistics.
        This is a protected permission, meaning the user must grant it from
        a special screen in the device's Settings. We will handle this flow in our code.
        'tools:ignore="ProtectedPermissions"' is added to suppress the lint warning.
        (As per section 4.3.1 of the requirements)
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    
    <!-- Permission for showing notifications (required for Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Required for WorkManager to schedule background tasks -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Network permissions for REDCap API -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Permission to request battery optimization exemption -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.MonitorUtilizzoSTILMEQE">
        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding Activity -->
        <activity
            android:name=".onboarding.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.MonitorUtilizzoSTILMEQE" />

        <!-- Questionnaire Activity -->
        <activity
            android:name=".questionnaire.QuestionnaireActivity"
            android:exported="false"
            android:theme="@style/Theme.MonitorUtilizzoSTILMEQE" />

        <!-- Thank You Activity -->
        <activity
            android:name=".study.ThankYouActivity"
            android:exported="false"
            android:theme="@style/Theme.MonitorUtilizzoSTILMEQE" />

        <!-- Group Instructions Activity -->
        <activity
            android:name=".stl_guide.GroupInstructionsActivity"
            android:exported="false"
            android:theme="@style/Theme.MonitorUtilizzoSTILMEQE" />

        <!-- Permission Recovery Activity -->
        <activity
            android:name=".PermissionRecoveryActivity"
            android:exported="false"
            android:theme="@style/Theme.MonitorUtilizzoSTILMEQE" />
    </application>

</manifest>
