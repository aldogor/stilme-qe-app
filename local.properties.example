## This file is a template for local.properties.
## Copy this to local.properties and fill in your values.
## local.properties is git-ignored and must NOT be committed.

sdk.dir=/path/to/your/android/sdk

# REDCap configuration
REDCAP_API_TOKEN=YOUR_TOKEN_HERE
REDCAP_API_URL=https://www.medcap.unito.it/redcap/api/

# In-app update: direct download link to update-info.json on Google Drive
# See README.md for setup instructions
UPDATE_JSON_URL=https://drive.google.com/uc?export=download&id=YOUR_JSON_FILE_ID
